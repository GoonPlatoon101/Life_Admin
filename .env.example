# LifeAdmin environment configuration.
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- LLM ---
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3

# --- Optional read-only email polling ---
# EMAIL_PROVIDER=google
# EMAIL_ACCESS_TOKEN=replace-with-oauth-access-token
# EMAIL_QUERY=newer_than:1d
# EMAIL_MAX_RESULTS=10
# EMAIL_POLL_SECONDS=60
